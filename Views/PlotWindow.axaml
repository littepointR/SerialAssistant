<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:vm="using:SerialAssistant.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="SerialAssistant.Views.PlotWindow"
        x:DataType="vm:PlotWindowViewModel"
        Title="Serial Data Plotter"
        Width="800" Height="450">

    <Grid RowDefinitions="Auto, *">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10" Spacing="10">
            <Button Content="Clear Plot" Command="{Binding Clear}" />
        </StackPanel>
        
        <lvc:CartesianChart Grid.Row="1" Series="{Binding Series}" />
    </Grid>
</Window>