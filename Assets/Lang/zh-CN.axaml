<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    <system:String x:Key="AppTitle">串口调试助手</system:String>
    <system:String x:Key="Connection">连接设置</system:String>
    <system:String x:Key="PortName">端口号:</system:String>
    <system:String x:Key="BaudRate">波特率:</system:String>
    <system:String x:Key="DataBits">数据位:</system:String>
    <system:String x:Key="StopBits">停止位:</system:String>
    <system:String x:Key="Parity">校验位:</system:String>
    <system:String x:Key="Display">显示设置</system:String>
    <system:String x:Key="Timestamp">显示时间戳</system:String>
    <system:String x:Key="PauseUpdate">暂停刷新</system:String>
    <system:String x:Key="AutoScroll">自动滚动</system:String>
    <system:String x:Key="AutoFrameBreak">自动断帧</system:String>
    <system:String x:Key="Timeout">超时时间:</system:String>
    <system:String x:Key="OpenPlotter">打开绘图窗口</system:String>
    <system:String x:Key="ReceivedData">接收数据</system:String>
    <system:String x:Key="Clear">清空</system:String>
    <system:String x:Key="SendData">发送数据</system:String>
    <system:String x:Key="History">发送历史</system:String>
    <system:String x:Key="Send">发送</system:String>
    <system:String x:Key="SystemLogs">系统日志</system:String>
    <system:String x:Key="ClearLogs">清空日志</system:String>
    <system:String x:Key="QuickSends">快捷发送</system:String>
    <system:String x:Key="Add">添加</system:String>
    <system:String x:Key="JSScripts">JS 脚本</system:String>
    <system:String x:Key="AddScript">添加脚本</system:String>
    <system:String x:Key="ResetCounters">重置计数</system:String>
    
    <system:String x:Key="Settings">设置</system:String>
    <system:String x:Key="Language">语言</system:String>
    <system:String x:Key="Theme">主题模式</system:String>
    <system:String x:Key="ThemeColor">主题颜色</system:String>
    <system:String x:Key="Encoding">数据编码</system:String>
    <system:String x:Key="RxBufferSize">接收缓冲区</system:String>
    <system:String x:Key="FontSize">字体大小</system:String>
    <system:String x:Key="LineEnding">换行符</system:String>
    <system:String x:Key="ShowLineNum">显示行号</system:String>
</ResourceDictionary>