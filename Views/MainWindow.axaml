<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SerialAssistant.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="SerialAssistant.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{DynamicResource AppTitle}"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto, *, Auto">

        <!-- Header -->
        <material:ColorZone Grid.Row="0" Mode="PrimaryMid" Padding="12,8" ZIndex="100">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}" CornerRadius="8" Padding="8,4">
                        <avalonia:MaterialIcon Kind="SerialPort" Width="20" Height="20" />
                    </Border>
                    <TextBlock Text="{DynamicResource AppTitle}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" LetterSpacing="0.5"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Button Classes="Flat" Command="{Binding OpenHelpCommand}" ToolTip.Tip="{DynamicResource Help}" Padding="10" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <avalonia:MaterialIcon Kind="HelpCircleOutline" Width="18" Height="18"/>
                            <TextBlock Text="{DynamicResource Help}" FontSize="12" VerticalAlignment="Center" IsVisible="False"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="Flat" ToolTip.Tip="{DynamicResource Settings}" Padding="10" CornerRadius="8">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <material:ColorZone Mode="Standard" Padding="24" Margin="-12">
                                    <StackPanel Spacing="14" Width="320">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <avalonia:MaterialIcon Kind="Cog" Width="20" Height="20" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                            <TextBlock Text="{DynamicResource Settings}" FontWeight="SemiBold" FontSize="17"/>
                                        </StackPanel>

                                        <Separator Margin="0,2"/>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource Language}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource Theme}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource ThemeColor}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding ThemeColors}" SelectedItem="{Binding SelectedThemeColor}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Separator Margin="0,4"/>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource Encoding}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding Encodings}" SelectedItem="{Binding SelectedEncoding}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource RxBufferSize}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding BufferSizes}" SelectedItem="{Binding SelectedBufferSize}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource FontSize}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding FontSizes}" SelectedItem="{Binding SelectedFontSize}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource LineEnding}" VerticalAlignment="Center" FontSize="13"/>
                                            <ComboBox Grid.Column="1" ItemsSource="{Binding LineEndings}" SelectedItem="{Binding SelectedLineEnding}" Width="160" Padding="10,8"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*, Auto" Margin="0,2">
                                            <TextBlock Text="{DynamicResource ShowLineNum}" VerticalAlignment="Center" FontSize="13"/>
                                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding ShowLineNumbers}" MinHeight="30"/>
                                        </Grid>
                                    </StackPanel>
                                </material:ColorZone>
                            </Flyout>
                        </Button.Flyout>
                        <avalonia:MaterialIcon Kind="Cog" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </Grid>
        </material:ColorZone>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="295, Auto, *, Auto, 350" Margin="12">

            <!-- Left Panel -->
            <material:Card Grid.Column="0" Margin="0,0,0,0" Padding="16" VerticalAlignment="Stretch">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">
                        <!-- Connection Section -->
                        <StackPanel Spacing="4">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="CableData" Width="16" Height="16" Foreground="#00897B"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Connection}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                <ComboBox Grid.Column="0" Classes="Outline" Theme="{StaticResource OutlineComboBox}" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding AvailablePorts}" SelectedItem="{Binding SelectedPort}"
                                          IsEnabled="{Binding !IsConnected}" PlaceholderText="{DynamicResource PortName}" MinHeight="40" Padding="12,8" />
                                <Button Grid.Column="1" Classes="Flat" Command="{Binding RefreshPortsCommand}" IsEnabled="{Binding !IsConnected}" Margin="8,0,0,0" Padding="10" CornerRadius="8">
                                    <avalonia:MaterialIcon Kind="Refresh" Width="18" Height="18" />
                                </Button>
                            </Grid>

                            <ComboBox Classes="Outline" Theme="{StaticResource OutlineComboBox}" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding BaudRates}" SelectedItem="{Binding SelectedBaudRate}"
                                      IsEnabled="{Binding !IsConnected}" PlaceholderText="{DynamicResource BaudRate}" MinHeight="40" Padding="12,8" Margin="0,6,0,0"/>

                            <Grid ColumnDefinitions="*, *" Margin="0,6,0,0">
                                <ComboBox Grid.Column="0" Classes="Outline" Theme="{StaticResource OutlineComboBox}" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding DataBitsList}" SelectedItem="{Binding SelectedDataBits}"
                                          IsEnabled="{Binding !IsConnected}" PlaceholderText="{DynamicResource DataBits}" MinHeight="40" Padding="12,8" Margin="0,0,4,0"/>

                                <ComboBox Grid.Column="1" Classes="Outline" Theme="{StaticResource OutlineComboBox}" HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding StopBitsList}" SelectedItem="{Binding SelectedStopBits}"
                                          IsEnabled="{Binding !IsConnected}" PlaceholderText="{DynamicResource StopBits}" MinHeight="40" Padding="12,8" Margin="4,0,0,0"/>
                            </Grid>

                            <ComboBox Classes="Outline" Theme="{StaticResource OutlineComboBox}" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding ParityList}" SelectedItem="{Binding SelectedParity}"
                                      IsEnabled="{Binding !IsConnected}" PlaceholderText="{DynamicResource Parity}" MinHeight="40" Padding="12,8" Margin="0,6,0,0"/>

                            <Button Classes="Dark" Command="{Binding ConnectCommand}" Content="{Binding ConnectButtonText}"
                                    HorizontalAlignment="Stretch" MinHeight="42" Margin="0,10,0,0" CornerRadius="8"/>
                        </StackPanel>

                        <Separator Margin="0,4"/>

                        <!-- Display Section -->
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="{DynamicResource SystemControlBackgroundAltMediumHighBrush}" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="Monitor" Width="16" Height="16" Foreground="#5C6BC0"/>
                                </Border>
                                <TextBlock Text="{DynamicResource Display}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>

                            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <CheckBox Content="{DynamicResource Timestamp}" IsChecked="{Binding ShowTimestamp}" Margin="0,0,16,6" FontSize="12" MinHeight="28" />
                                <CheckBox Content="{DynamicResource PauseUpdate}" IsChecked="{Binding PauseUpdate}" Margin="0,0,16,6" FontSize="12" MinHeight="28" />
                                <CheckBox Content="{DynamicResource AutoScroll}" IsChecked="{Binding AutoScroll}" Margin="0,0,0,6" FontSize="12" MinHeight="28" />
                            </WrapPanel>

                            <CheckBox Content="{DynamicResource AutoFrameBreak}" IsChecked="{Binding AutoFrameBreak}" FontSize="12" MinHeight="28"/>
                            <StackPanel Orientation="Horizontal" IsEnabled="{Binding AutoFrameBreak}" Spacing="8" Margin="28,0,0,0">
                                <TextBlock Text="{DynamicResource Timeout}" VerticalAlignment="Center" FontSize="12"/>
                                <NumericUpDown Value="{Binding FrameBreakTimeoutMs}" Minimum="10" Maximum="5000" Width="110" MinHeight="30" Padding="8,4" />
                                <TextBlock Text="ms" VerticalAlignment="Center" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,4"/>

                        <!-- Plotter Button -->
                        <Button Classes="Outline" Command="{Binding OpenPlotterCommand}" HorizontalAlignment="Stretch" MinHeight="42" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <avalonia:MaterialIcon Kind="ChartLine" Width="18" Height="18"/>
                                <TextBlock Text="{DynamicResource OpenPlotter}" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </material:Card>

            <!-- Splitter 1 -->
            <GridSplitter Grid.Column="1" Background="Transparent" Width="12" ResizeDirection="Columns" />

            <!-- Center Panel -->
            <Grid Grid.Column="2" RowDefinitions="*, Auto, 140" Margin="0">

                <!-- Received Data -->
                <material:Card Grid.Row="0" Margin="0,0,0,10" Padding="14">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#E8F5E9" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="Download" Width="16" Height="16" Foreground="#43A047"/>
                                </Border>
                                <TextBlock Text="{DynamicResource ReceivedData}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <ToggleSwitch Content="HEX" IsChecked="{Binding IsHexReceive}" VerticalAlignment="Center" FontSize="12" MinHeight="28"/>
                                <Button Classes="Flat" Command="{Binding ClearCommand}" ToolTip.Tip="{DynamicResource Clear}" Padding="8" CornerRadius="6" MinHeight="32" MinWidth="32">
                                    <avalonia:MaterialIcon Kind="DeleteSweep" Width="18" Height="18" />
                                </Button>
                            </StackPanel>
                        </Grid>
                        <TextBox Name="RxTextBox" Grid.Row="1" Classes="Outline" Theme="{StaticResource OutlineTextBox}"
                                 Text="{Binding ReceivedData}" AcceptsReturn="True" IsReadOnly="True"
                                 TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Courier New, monospace" FontSize="{Binding SelectedFontSize}" Padding="10"/>
                    </Grid>
                </material:Card>

                <!-- Send Data -->
                <material:Card Grid.Row="1" Margin="0,0,0,10" Padding="14">
                    <Grid RowDefinitions="Auto, Auto">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto, Auto" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#E3F2FD" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="Upload" Width="16" Height="16" Foreground="#1E88E5"/>
                                </Border>
                                <TextBlock Text="{DynamicResource SendData}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                <ComboBox Classes="Outline" Theme="{StaticResource OutlineComboBox}"
                                          ItemsSource="{Binding SendHistory}" SelectedItem="{Binding SelectedSendHistory}" Width="140" PlaceholderText="{DynamicResource History}" MinHeight="32" Padding="8,6" FontSize="12"/>
                                <ToggleSwitch Content="HEX" IsChecked="{Binding IsHexSend}" VerticalAlignment="Center" FontSize="12" MinHeight="28"/>
                            </StackPanel>
                        </Grid>
                        <Grid Grid.Row="1" ColumnDefinitions="*, Auto">
                            <TextBox Name="TxTextBox" Grid.Column="0" Classes="Outline" Theme="{StaticResource OutlineTextBox}"
                                     Text="{Binding DataToSend}" AcceptsReturn="True"
                                     TextWrapping="Wrap" Height="72" ScrollViewer.VerticalScrollBarVisibility="Auto" FontFamily="Consolas, Courier New, monospace" FontSize="{Binding SelectedFontSize}" Padding="10"/>
                            <Button Grid.Column="1" Classes="Dark" Command="{Binding SendCommand}" Margin="12,0,0,0" Width="72" MinHeight="72" CornerRadius="8">
                                <StackPanel HorizontalAlignment="Center">
                                    <avalonia:MaterialIcon Kind="Send" Width="22" Height="22" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{DynamicResource Send}" HorizontalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </material:Card>

                <!-- Logs -->
                <material:Card Grid.Row="2" Padding="14">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#FFF3E0" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="ScriptText" Width="16" Height="16" Foreground="#FB8C00"/>
                                </Border>
                                <TextBlock Text="{DynamicResource SystemLogs}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="Flat" Command="{Binding ClearLogCommand}" ToolTip.Tip="{DynamicResource ClearLogs}" Padding="6" CornerRadius="6" MinHeight="28" MinWidth="28">
                                <avalonia:MaterialIcon Kind="DeleteSweep" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                        <TextBox Grid.Row="1" Classes="Outline" Theme="{StaticResource OutlineTextBox}"
                                 Text="{Binding LogData}" AcceptsReturn="True" IsReadOnly="True"
                                 TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" FontSize="11" Padding="8"/>
                    </Grid>
                </material:Card>
            </Grid>

            <!-- Splitter 2 -->
            <GridSplitter Grid.Column="3" Background="Transparent" Width="12" ResizeDirection="Columns" />

            <!-- Right Panel -->
            <Grid Grid.Column="4" RowDefinitions="*, *">

                <!-- Quick Sends -->
                <material:Card Grid.Row="0" Margin="0,0,0,6" Padding="14">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#FCE4EC" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="RocketLaunch" Width="16" Height="16" Foreground="#E91E63"/>
                                </Border>
                                <TextBlock Text="{DynamicResource QuickSends}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="Flat" Command="{Binding AddQuickSendCommand}" ToolTip.Tip="{DynamicResource Add}" Padding="8" CornerRadius="6" MinHeight="32" MinWidth="32">
                                <avalonia:MaterialIcon Kind="Add" Width="18" Height="18" />
                            </Button>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding QuickSends}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="10">
                                            <Grid ColumnDefinitions="Auto, *, Auto, Auto" RowDefinitions="Auto, Auto">
                                                <TextBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Text="{Binding Name}" Classes="Clear" Margin="0,0,0,6" FontWeight="Medium" FontSize="12" MinHeight="28" Padding="6,4"/>
                                                <ToggleSwitch Grid.Row="0" Grid.Column="2" Content="HEX" IsChecked="{Binding IsHex}" Margin="8,0" VerticalAlignment="Center" FontSize="10" MinHeight="24"/>
                                                <Button Grid.Row="0" Grid.Column="3" Classes="Flat" Command="{Binding RemoveCommand}" Foreground="#E53935" ToolTip.Tip="Remove" Padding="4" MinHeight="24" MinWidth="24">
                                                    <avalonia:MaterialIcon Kind="Close" Width="14" Height="14"/>
                                                </Button>

                                                <TextBox Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Text="{Binding Data}" Classes="Outline" Theme="{StaticResource OutlineTextBox}" Margin="0,0,8,0" FontSize="12" MinHeight="28" Padding="8,6"/>
                                                <Button Grid.Row="1" Grid.Column="3" Classes="Light" Command="{Binding SendCommand}" ToolTip.Tip="Send" Padding="6" MinHeight="28" MinWidth="28">
                                                    <avalonia:MaterialIcon Kind="Send" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </material:Card>

                <!-- JS Scripts -->
                <material:Card Grid.Row="1" Margin="0,6,0,0" Padding="14">
                    <Grid RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Border Background="#F3E5F5" CornerRadius="6" Padding="6">
                                    <avalonia:MaterialIcon Kind="CodeBraces" Width="16" Height="16" Foreground="#8E24AA"/>
                                </Border>
                                <TextBlock Text="{DynamicResource JSScripts}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button Grid.Column="1" Classes="Flat" Command="{Binding AddScriptCommand}" ToolTip.Tip="{DynamicResource AddScript}" Padding="8" CornerRadius="6" MinHeight="32" MinWidth="32">
                                <avalonia:MaterialIcon Kind="Add" Width="18" Height="18" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding JsScripts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,8" Padding="10">
                                            <Grid RowDefinitions="Auto, Auto, *">
                                                <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto">
                                                    <ToggleSwitch Grid.Column="0" IsChecked="{Binding IsEnabled}" Content="" Margin="0,0,8,0" VerticalAlignment="Center" MinHeight="24"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Name}" Classes="Clear" VerticalAlignment="Center" FontWeight="Medium" FontSize="12" MinHeight="28" Padding="6,4"/>
                                                    <Button Grid.Column="2" Classes="Flat" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RemoveScriptCommand}" CommandParameter="{Binding}" Foreground="#E53935" ToolTip.Tip="Remove" Padding="4" MinHeight="24" MinWidth="24">
                                                        <avalonia:MaterialIcon Kind="Close" Width="14" Height="14"/>
                                                    </Button>
                                                </Grid>

                                                <Grid Grid.Row="1" ColumnDefinitions="Auto, Auto, *" Margin="0,6">
                                                    <ToggleSwitch Grid.Column="0" IsChecked="{Binding IsTimerEnabled}" Content="Timer" Margin="0,0,8,0" IsEnabled="{Binding IsEnabled}" FontSize="10" MinHeight="24"/>
                                                    <NumericUpDown Grid.Column="1" Value="{Binding TimerIntervalMs}" Minimum="10" Maximum="60000" Width="90" IsVisible="{Binding TimerSettingsVisible}" IsEnabled="{Binding IsEnabled}" FontSize="12" MinHeight="28" Padding="6,4"/>
                                                    <TextBlock Grid.Column="2" Text="ms" VerticalAlignment="Center" Margin="8,0,0,0" IsVisible="{Binding TimerSettingsVisible}" FontSize="11"/>
                                                </Grid>

                                                <TextBox Grid.Row="2" Classes="Outline" Theme="{StaticResource OutlineTextBox}" Text="{Binding ScriptContent}" AcceptsReturn="True" AcceptsTab="True"
                                                         FontFamily="Consolas, Courier New, monospace" Height="115" ScrollViewer.VerticalScrollBarVisibility="Auto" IsEnabled="{Binding IsEnabled}" FontSize="11" Padding="8" Margin="0,6,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </material:Card>
            </Grid>
        </Grid>

        <!-- Status Bar -->
        <material:ColorZone Grid.Row="2" Mode="Standard" Padding="12,8" ZIndex="100">
            <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,24,0">
                    <avalonia:MaterialIcon Kind="ArrowDownBold" Width="14" Height="14" Foreground="#43A047" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Rx:" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RxCount}" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="bytes" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,24,0">
                    <avalonia:MaterialIcon Kind="ArrowUpBold" Width="14" Height="14" Foreground="#1E88E5" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Tx:" FontWeight="Medium" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TxCount}" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="bytes" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="4,0,0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Rx Sel:" Foreground="#009688" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RxSelectionCharCount}" Foreground="#009688" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="chars" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,8,1"/>
                    <TextBlock Text="{Binding RxSelectionHexCount}" Foreground="#009688" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="hex" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                </StackPanel>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Margin="0,0,24,0">
                    <TextBlock Text="Tx Sel:" Foreground="#009688" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TxSelectionCharCount}" Foreground="#009688" FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    <TextBlock Text="chars" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,8,1"/>
                    <TextBlock Text="{Binding TxSelectionHexCount}" Foreground="#009688" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="hex" Foreground="{DynamicResource SystemControlForegroundBaseMediumHighBrush}" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,0,1"/>
                </StackPanel>

                <Button Grid.Column="5" Classes="Flat" Command="{Binding ClearCountersCommand}" Padding="10,6" CornerRadius="6">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <avalonia:MaterialIcon Kind="Restart" Width="14" Height="14"/>
                        <TextBlock Text="{DynamicResource ResetCounters}" FontSize="11"/>
                    </StackPanel>
                </Button>
            </Grid>
        </material:ColorZone>
    </Grid>
</Window>
